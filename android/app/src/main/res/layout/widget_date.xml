<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_ios26_bg"
    android:padding="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Месяц сверху -->
        <TextView
            android:id="@+id/widget_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#FF0A84FF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <!-- День -->
        <TextView
            android:id="@+id/widget_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="-2dp" />
    </LinearLayout>

    <!-- Кнопки быстрого действия (скрыты по умолчанию, показываются при long press) -->
    <LinearLayout
        android:id="@+id/widget_quick_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginBottom="4dp">

        <ImageButton
            android:id="@+id/btn_add_event"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/widget_btn_bg"
            android:src="@android:drawable/ic_menu_my_calendar"
            android:scaleType="centerInside"
            android:contentDescription="Мероприятие"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btn_add_task"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/widget_btn_bg"
            android:src="@android:drawable/ic_menu_agenda"
            android:scaleType="centerInside"
            android:contentDescription="Задача" />
    </LinearLayout>
</FrameLayout>
