<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_ios26_bg"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="top|start"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_weekday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFF3344"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="true"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginEnd="76dp" />

        <TextView
            android:id="@+id/widget_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="40sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:includeFontPadding="false"
            android:layout_marginEnd="76dp" />

        <LinearLayout
            android:id="@+id/event_slot_0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/widget_event_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone">
            <ImageView android:id="@+id/dot_0" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="8dp" />
            <TextView android:id="@+id/time_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#80FFFFFF" android:textSize="12sp" android:fontFamily="sans-serif-medium" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/title_0" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#FFFFFFFF" android:textSize="12sp" android:fontFamily="sans-serif-medium" android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/event_slot_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/widget_event_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone">
            <ImageView android:id="@+id/dot_1" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="8dp" />
            <TextView android:id="@+id/time_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#80FFFFFF" android:textSize="12sp" android:fontFamily="sans-serif-medium" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/title_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#FFFFFFFF" android:textSize="12sp" android:fontFamily="sans-serif-medium" android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/event_slot_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/widget_event_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone">
            <ImageView android:id="@+id/dot_2" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="8dp" />
            <TextView android:id="@+id/time_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#80FFFFFF" android:textSize="12sp" android:fontFamily="sans-serif-medium" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/title_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#FFFFFFFF" android:textSize="12sp" android:fontFamily="sans-serif-medium" android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/event_slot_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/widget_event_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone">
            <ImageView android:id="@+id/dot_3" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="8dp" />
            <TextView android:id="@+id/time_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#80FFFFFF" android:textSize="12sp" android:fontFamily="sans-serif-medium" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/title_3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#FFFFFFFF" android:textSize="12sp" android:fontFamily="sans-serif-medium" android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_events_text"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:text="@string/no_events"
            android:gravity="top|start"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/widget_more_events"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#99FFFFFF"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="italic"
            android:visibility="gone" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/btn_add_container"
        android:layout_width="70dp"
        android:layout_height="50dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="2dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/btn_add"
            android:layout_width="40dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/widget_btn_pill"
            android:src="@drawable/widget_ic_add"
            android:scaleType="centerInside" />

    </FrameLayout>
</FrameLayout>
