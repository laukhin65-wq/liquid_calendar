<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="270"
                android:startColor="#33FFFFFF" android:endColor="#1AFFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="270"
                android:startColor="#4DFFFFFF" android:centerColor="#00FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#59FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
