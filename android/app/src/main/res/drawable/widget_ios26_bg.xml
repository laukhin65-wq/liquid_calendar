<?xml version="1.0" encoding="utf-8"?>
<!-- Liquid Glass (iOS 26): полупрозрачное «дымчатое» стекло.
     Сквозь него слегка просвечивают обои, белый текст остаётся читаемым. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. Дымчатая стеклянная база -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#CC121216"
                android:centerColor="#591E1E24"
                android:endColor="#CC121216" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- 2. Верхний specular-блик -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#40FFFFFF"
                android:centerColor="#00FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- 3. Яркая линзовая кромка -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#66FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
